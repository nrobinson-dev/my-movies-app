{
  "ConnectionStrings": {
    "MyMoviesAppDbSource": "Data Source=MyMoviesApp.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TmdbSettings": {
    "ApiBaseUrl": "https://api.themoviedb.org/3/",
    "BearerToken": "YOUR_TMDB_API_ACCESS_TOKEN (But honestly, you should use .NET Secret Manager or environment variables for this)"
  },
  "JwtSettings": {
    "Issuer": "MyMoviesApp",
    "Audience": "MyMoviesApp.Client",
    "SigningKey": "YOUR_LONG_RANDOM_JWT_SIGNING_KEY",
    "AccessTokenExpirationMinutes": 60
  }
}
