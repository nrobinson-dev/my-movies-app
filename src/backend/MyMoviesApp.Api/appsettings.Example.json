{
  "AllowedHosts": "*",
  "AllowedOrigins": [],
  "ConnectionStrings": {
    "MyMoviesAppDbSource": "Data Source=/home/MyMoviesApp.db",
    "Redis": "THIS_IS_A_PLACEHOLDER_REDIS_CONNECTION_STRING (Use .NET Secret Manager or environment variables for this in a real app)"
  },
  "JwtSettings": {
    "Issuer": "MyMoviesApp",
    "Audience": "MyMoviesApp.Client",
    "SigningKey": "YOUR_LONG_RANDOM_JWT_SIGNING_KEY",
    "AccessTokenExpirationMinutes": 60
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/myMoviesApp-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "TmdbSettings": {
    "ApiBaseUrl": "https://api.themoviedb.org/3/",
    "BearerToken": "YOUR_TMDB_API_ACCESS_TOKEN (But honestly, you should use .NET Secret Manager or environment variables for this)"
  }
}
